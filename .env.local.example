# WordPress REST API URL (sin trailing slash)
NEXT_PUBLIC_WORDPRESS_URL=https://tu-sitio-wordpress.com

# Opcional: WordPress Application Password para contenido protegido
# WP_AUTH_USER=admin
# WP_AUTH_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Opcional: activar revalidación ISR (en segundos)
REVALIDATE_SECONDS=60
