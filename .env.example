# Ruta del archivo SQLite dentro del contenedor Docker
# El directorio /app/data es persistido como volumen Docker
DATABASE_URL=/app/data/payload.db

# Clave secreta de Payload - genera una clave aleatoria larga (min 32 caracteres)
# Puedes generar una con: openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE
